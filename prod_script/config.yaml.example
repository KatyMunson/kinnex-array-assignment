# =============================================================================
# config.yaml — Kinnex Iso-seq Production Pipeline
# =============================================================================

# Path to the run manifest (tab-separated, see manifest.tab.example)
manifest: manifest.tab

# FASTA inputs
primers_fasta:  primers/primers.fasta
adapters_fasta: adapters/adapters.fasta

# Script paths (relative to this config file / Snakefile location)
assign_script:          scripts/assign_kinnex.py
split_skera_script:     scripts/split_skera_by_library.py
aggregate_script:       scripts/aggregate_flnc_qc.py
pipeline_qc_script:     scripts/aggregate_pipeline_qc.py
sankey_script:          scripts/generate_sankey.py
plot_posteriors_script: scripts/plot_posteriors.py

# Lima pass 1 options (barcode detection for array assignment; multi-library only)
# --no-output suppresses BAM writing; only the .lima.report is needed.
# These values are intentionally conservative relative to PacBio defaults
# (min_score default=0, min_ref_span default=0.25) to reduce ambiguous calls.
# If pass 1 yield is unexpectedly low, try relaxing min_score and min_ref_span.
lima_pass1:
  min_score:      80
  min_score_lead: 10
  min_ref_span:   0.75

# IsoSeq refine options
refine:
  require_polya:    true
  min_polya_length: 20

# Per-rule SGE resources
# mem is GB per slot (per thread). SGE multiplies mem × threads for total.
# The attempt multiplier provides automatic memory escalation on retries.
# Recommended submission flag: --retries 3
resources:
  skera:
    threads: 8
    mem: 1      # 1 GB/slot × 8 threads = 8 GB total
    hrs: 6
  lima:
    threads: 8
    mem: 1      # 1 GB/slot × 8 threads = 8 GB total
    hrs: 12
  refine:
    threads: 8
    mem: 1      # 1 GB/slot × 8 threads = 8 GB total
    hrs: 8
  assign:
    threads: 2
    mem: 6      # 6 GB/slot × 2 threads = 12 GB total
    hrs: 8
  split:
    threads: 2
    mem: 6      # 6 GB/slot × 2 threads = 12 GB total
    hrs: 8
  aggregate:
    threads: 1
    mem: 4
    hrs: 1
  qc:
    threads: 1
    mem: 8
    hrs: 2
